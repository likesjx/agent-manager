{
  "name": "@likesjx/agent-manager",
  "version": "0.1.0",
  "description": "Repo-embeddable, provider-agnostic agent operations module",
  "type": "module",
  "bin": {
    "agent-manager": "./cli.js"
  },
  "scripts": {
    "validate": "bash scripts/validate.sh",
    "test": "node --test tests/*.test.js",
    "init:embedded": "node cli.js init --mode embedded --agent-id codex-local --provider claude-code --capabilities nodejs,workflow",
    "library:check": "node scripts/library-check.js",
    "workflow:check": "node scripts/workflow-check.js",
    "provider:render:claude": "node cli.js provider render --provider claude-code",
    "provider:install:claude": "node cli.js provider install --provider claude-code",
    "describe:system": "node cli.js describe system",
    "agent:list": "node cli.js agent list",
    "parity:check": "node scripts/rust-parity-check.js",
    "intake:sync:ado": "node cli.js intake sync --source ado",
    "intake:sync:itrack": "node cli.js intake sync --source itrack"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
